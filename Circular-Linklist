#include<iostream>
using namespace std;

// ================= NODE STRUCTURE =================
struct Node {
    int data;
    Node* next;
};

// ============== CIRCULAR LINKED LIST CLASS ==============
class CircularLinkedList {
private:
    Node* head;

public:

    // ================= CONSTRUCTOR =================
    CircularLinkedList() {
        head = nullptr;
    }

    // ================= INSERT AT START =================
    void insertAtStart(int data) {

        Node* temp = new Node{data, nullptr};

        // Empty list
        if (head == nullptr) {
            head = temp;
            temp->next = head;
            return;
        }

        Node* current = head;

        // Reach last node
        while (current->next != head) {
            current = current->next;
        }

        temp->next = head;
        current->next = temp;
        head = temp;
    }
 // ================= INSERT AT END =================
    void insertAtEnd(int data) {

        Node* temp = new Node{data, nullptr};

        // Empty list
        if (head == nullptr) {
            head = temp;
            temp->next = head;
            return;
        }

        Node* current = head;

        while (current->next != head) {
            current = current->next;
        }

        current->next = temp;
        temp->next = head;
    }
    
  // ================= INSERT AT POSITION =================
    void insertAtPosition(int data, int pos) {

        // Insert at start
        if (pos == 1) {
            insertAtStart(data);
            return;
        }

        Node* current = head;

        for (int i = 1; i < pos - 1 && current->next != head; i++) {
            current = current->next;
        }

        Node* temp = new Node{data, nullptr};

        temp->next = current->next;
        current->next = temp;
    }
     // ================= DELETE FROM START =================
    void deleteFromStart() {

        if (head == nullptr) {
            cout << "List is empty\n";
            return;
        }

        // Single node
        if (head->next == head) {
            delete head;
            head = nullptr;
            return;
        }

        Node* current = head;

        while (current->next != head) {
            current = current->next;
        }

        Node* temp = head;

        head = head->next;
        current->next = head;

        delete temp;
    }
      // ================= DELETE FROM END =================
    void deleteFromEnd() {

        if (head == nullptr) {
            cout << "List is empty\n";
            return;
        }

        // Single node
        if (head->next == head) {
            delete head;
            head = nullptr;
            return;
        }

        Node* current = head;

        while (current->next->next != head) {
            current = current->next;
        }

        delete current->next;
        current->next = head;
    }
    
    // ================= DELETE AT POSITION =================
    void deleteAtPosition(int pos) {

        if (head == nullptr) {
            cout << "List is empty\n";
            return;
        }

        if (pos == 1) {
            deleteFromStart();
            return;
        }

        Node* current = head;

        for (int i = 1; i < pos - 1 && current->next != head; i++) {
            current = current->next;
        }

        Node* temp = current->next;

        // Invalid position
        if (temp == head) {
            cout << "Invalid Position\n";
            return;
        }

        current->next = temp->next;

        delete temp;
    }
     // ================= SEARCH =================
    void search(int key) {

        if (head == nullptr) {
            cout << "List is empty\n";
            return;
        }

        Node* current = head;
        int pos = 1;

        do {
            if (current->data == key) {
                cout << "Element found at position: " << pos << endl;
                return;
            }

            current = current->next;
            pos++;

        } while (current != head);

        cout << "Element not found\n";
    }
      // ================= DISPLAY =================
    void display() {

        if (head == nullptr) {
            cout << "List is empty\n";
            return;
        }

        Node* current = head;

        do {
            cout << current->data << " -> ";
            current = current->next;

        } while (current != head);

        cout << "(HEAD)\n";
    }
     // ================= COUNT NODES =================
    void countNodes() {

        if (head == nullptr) {
            cout << "Total Nodes: 0\n";
            return;
        }

        int count = 0;
        Node* current = head;

        do {
            count++;
            current = current->next;

        } while (current != head);

        cout << "Total Nodes: " << count << endl;
    }

    // ================= DESTRUCTOR =================
    ~CircularLinkedList() {

        if (head == nullptr)
            return;

        Node* current = head->next;

        while (current != head) {

            Node* temp = current;
            current = current->next;
            delete temp;
        }

        delete head;
    }
};

// ================= MAIN FUNCTION =================
int main() {

    CircularLinkedList list;

    int choice, data, pos;

    do {

        cout << "\n====== Circular Linked List Menu ======\n";

        cout << "1. Insert At Start\n";
        cout << "2. Insert At End\n";
        cout << "3. Insert At Position\n";
        cout << "4. Delete From Start\n";
        cout << "5. Delete From End\n";
        cout << "6. Delete At Position\n";
        cout << "7. Search Element\n";
        cout << "8. Display List\n";
        cout << "9. Count Nodes\n";
        cout << "0. Exit\n";

        cout << "Enter Choice: ";
        cin >> choice;

        switch (choice) {

        case 1:
            cout << "Enter data: ";
            cin >> data;
            list.insertAtStart(data);
            break;

        case 2:
            cout << "Enter data: ";
            cin >> data;
            list.insertAtEnd(data);
            break;

        case 3:
            cout << "Enter data and position: ";
            cin >> data >> pos;
            list.insertAtPosition(data, pos);
            break;

        case 4:
            list.deleteFromStart();
            break;

        case 5:
            list.deleteFromEnd();
            break;

        case 6:
            cout << "Enter position: ";
            cin >> pos;
            list.deleteAtPosition(pos);
            break;

        case 7:
            cout << "Enter element to search: ";
            cin >> data;
            list.search(data);
            break;

        case 8:
            list.display();
            break;

        case 9:
            list.countNodes();
            break;

        case 0:
            cout << "Exiting Program...\n";
            break;

        default:
            cout << "Invalid Choice\n";
        }

    } while (choice != 0);

    return 0;
}